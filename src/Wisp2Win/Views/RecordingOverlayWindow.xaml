<Window x:Class="Wisp2Win.Views.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="168"
        Height="64"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Opacity="0">
    <Window.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="1.34"
                             Duration="0:0:1.15"
                             AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.34"
                             Duration="0:0:1.15"
                             AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.46"
                             To="0.12"
                             Duration="0:0:1.15"
                             AutoReverse="True" />
        </Storyboard>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="0.96"
                             Duration="0:0:0.18" />
        </Storyboard>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.20" />
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="28"
            Background="#F7FFFFFF"
            BorderBrush="#220F172A"
            BorderThickness="1"
            Padding="12"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="8"
                              Direction="270"
                              Opacity="0.22"
                              Color="#0F172A" />
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <Grid Width="40" Height="40" DockPanel.Dock="Left">
                <Ellipse x:Name="PulseRing"
                         Fill="#FCA5A5"
                         Width="28"
                         Height="28"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="PulseScale" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Fill="#EF4444"
                         Width="28"
                         Height="28"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <Path Fill="White"
                      Stretch="Uniform"
                      Width="14"
                      Height="20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Data="M8,1 C6.34,1 5,2.34 5,4 L5,10 C5,11.66 6.34,13 8,13 C9.66,13 11,11.66 11,10 L11,4 C11,2.34 9.66,1 8,1 Z M3,9 L3,10 C3,12.76 5.24,15 8,15 C10.76,15 13,12.76 13,10 L13,9 L15,9 L15,10 C15,13.52 12.39,16.43 9,16.92 L9,19 L12,19 L12,21 L4,21 L4,19 L7,19 L7,16.92 C3.61,16.43 1,13.52 1,10 L1,9 Z" />
            </Grid>

            <StackPanel Margin="10,0,4,0"
                        VerticalAlignment="Center">
                <TextBlock Text="Запись"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#0F172A" />
                <TextBlock x:Name="ElapsedText"
                           Text="00:00"
                           Margin="0,1,0,0"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="#64748B" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
