<Window x:Class="Wisp2Win.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Wisp2Win.Models"
        Title="Wisp2Win"
        Icon="/Assets/app.ico"
        Width="560"
        Height="640"
        MinWidth="520"
        MinHeight="500"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel>
                <TextBlock Text="Wisp2Win"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="{Binding Status}"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
            <Button DockPanel.Dock="Right"
                    Width="180"
                    Height="42"
                    Command="{Binding ToggleCommand}"
                    Content="{Binding ToggleText}" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,22,0,0"
                Padding="16"
                CornerRadius="8"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Модель" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox Grid.Row="1"
                          Grid.Column="0"
                          Margin="0,6,12,16"
                          ItemsSource="{Binding Models}"
                          SelectedItem="{Binding SelectedModel}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Язык" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="12,6,0,16"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding Language}">
                    <ComboBoxItem Content="ru" />
                    <ComboBoxItem Content="en" />
                    <ComboBoxItem Content="auto" />
                </ComboBox>

                <WrapPanel Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,12">
                    <CheckBox Margin="0,0,18,0"
                              IsChecked="{Binding PasteAfterTranscription}"
                              Content="Вставлять в активное окно" />
                    <CheckBox Margin="0,0,18,0"
                              IsChecked="{Binding PolishTranscript}"
                              Content="Улучшать текст" />
                    <CheckBox IsChecked="{Binding TranslateToEnglish}"
                              Content="Переводить на английский" />
                </WrapPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Горячая клавиша" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox Grid.Row="4"
                          Grid.Column="0"
                          Margin="0,6,12,0"
                          ItemsSource="{Binding Hotkeys}"
                          SelectedItem="{Binding SelectedHotkey}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Способ вставки" Foreground="{StaticResource MutedTextBrush}" />
                <ComboBox Grid.Row="6"
                          Grid.Column="0"
                          Margin="0,6,12,0"
                          ItemsSource="{Binding PasteShortcuts}"
                          SelectedItem="{Binding SelectedPasteShortcut}"
                          DisplayMemberPath="DisplayName" />

                <StackPanel Grid.Row="4" Grid.Column="1" Grid.RowSpan="3" Margin="12,0,0,0">
                    <DockPanel>
                        <TextBlock Text="Статус модели" Foreground="{StaticResource MutedTextBrush}" />

                        <!--  Installed badge  -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Visibility="{Binding IsModelInstalled, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="✓ Установлена"
                                       Foreground="#16A34A"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!--  Download button (hidden when installed or downloading)  -->
                        <Button DockPanel.Dock="Right"
                                Width="96"
                                Height="28"
                                Command="{Binding DownloadModelCommand}"
                                Content="Скачать">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModelInstalled}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DockPanel>

                    <!--  Progress bar: only while downloading  -->
                    <ProgressBar Height="8"
                                 Margin="0,8,0,0"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="{Binding DownloadProgress}"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}" />

                    <CheckBox Margin="0,16,0,0"
                              IsChecked="{Binding ShowRecordingOverlay}"
                              Content="Показывать индикатор записи" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="12"
                CornerRadius="8"
                Background="#EFF6FF"
                BorderBrush="#BFDBFE"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="96"
                        Height="28"
                        Command="{Binding OpenLogsCommand}"
                        Content="Логи" />
                <TextBlock Text="{Binding HotkeyStatusText}"
                           VerticalAlignment="Center"
                           Foreground="#1D4ED8" />
            </DockPanel>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="12"
                CornerRadius="8"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="128"
                        Height="32"
                        Margin="8,0,0,0"
                        Command="{Binding ExportTranscriptCommand}"
                        Content="Экспорт TXT"
                        IsEnabled="{Binding CanExportTranscript}" />
                <Button DockPanel.Dock="Right"
                        Width="148"
                        Height="32"
                        Command="{Binding ImportAudioCommand}"
                        Content="Импорт аудио"
                        IsEnabled="{Binding CanStartImport}" />
                <TextBlock Text="Файлы"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
            </DockPanel>
        </Border>

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="8"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Последняя расшифровка"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBox Margin="0,10,0,0"
                         Text="{Binding LastTranscript}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
